{
  "manifest_version": 3,
  "name": "ChatGPT API Bridge",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
